generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?  @unique
  password   String?
  avatar     String?
  role       String   @default("user")
  phone      String   @default("")
  createdAt  DateTime @default(now())
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)

  details       UserDetails?
  deltaAccounts DeltaAccount[]
  tradeConfigs  TradeConfig[]
  Billing       Billing[]
  Payment       Payment[]
}

model DeltaAccount {
  id                 String   @id @default(cuid())
  userId             String
  accountType        String   @default("main")
  accountName        String   @default("Main Account")
  api_key_enc        String   @default("")
  api_secret_enc     String   @default("")
  delta_account_name String?
  delta_user_id      String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  oauth_access_token  String?
  oauth_refresh_token String?
  oauth_expires_at    DateTime?
  is_oauth            Boolean  @default(false)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeConfigs TradeConfig[]

  @@unique([userId, accountType])
  @@index([userId])
}

model TradeConfig {
  id             String   @id @default(cuid())
  userId         String
  accountId      String
  script         String
  amount         Float
  equityBalance  Float?   // per-bot running balance for 'equity_pct' mode strategies — starts at `amount`, updated by realized P&L after each exit, keeps compounding scoped to this bot's own capital rather than the whole Delta account balance
  initial_amount Float?
  isActive       Boolean  @default(false)
  userActive     Boolean  @default(true)
  comission      Float?
  createdAt      DateTime @default(now())

  webhookToken   String   @unique @default(cuid())
  leverage       Int      @default(1)
  compoundMode   String   @default("fixed")

  mode          String  @default("bridge")
  strategy      String?
  timeframe     String?
  session_start String?
  session_end   String?
  risk_reward   Float   @default(3.0)

  platformFeePercent  Float     @default(20)
  lastToggledAt       DateTime?
  pause_lastToggledAt DateTime?
  lastEditAt          DateTime?

  strategyId      String?
  isSubscription  Boolean   @default(false)
  strategyRef     Strategy? @relation(fields: [strategyId], references: [id])

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account DeltaAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  Billing Billing[]

  @@unique([accountId, script])
  @@index([isActive])
  @@index([webhookToken])
}

model UserDetails {
  id               String  @id @default(cuid())
  userId           String  @unique
  name             String
  age              Int
  gender           String
  city             String
  district         String
  country          String
  email            String
  phone            String
  deltaUserId      String?
  deltaAccountName String?
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  userId     String?
  createdAt  DateTime @default(now())
}

model Script {
  symbol          String  @id
  exchange_symbol String
  lot             Float   @default(1)
  exchange        String  @default("delta")
  algorithm       String?
  productId       Int
  Max_pos_size    Int     @default(15000)
  Pos_Per         Int     @default(100)
  gridEnabled     Boolean @default(false)
  defaultStrategy String?
}

model Billing {
  id                 String   @id @default(cuid())
  userId             String
  tradeConfigId      String
  month              String
  productId          Int
  netPnl             Float
  carryForward       Float    @default(0)
  billableAmount     Float
  platformFeePercent Float    @default(20)
  status             String   @default("unpaid")
  generatedAt        DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeConfig TradeConfig @relation(fields: [tradeConfigId], references: [id], onDelete: Cascade)
  Payment     Payment[]

  @@unique([month, tradeConfigId, productId])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  billingId         String?
  amountPaid        Float
  paymentDate       DateTime @default(now())
  method            String?
  razorpayPaymentId String?
  reference         String?
  screenshotUrl     String?
  confirmedByAdmin  Boolean  @default(false)
  confirmedAt       DateTime?
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  billing Billing? @relation(fields: [billingId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id                 String   @id @default("singleton")
  platformFeePercent Float    @default(20)
  upiQrImageUrl      String?  @db.Text
  upiId              String?
  adminWhatsapp      String?
  updatedAt          DateTime @updatedAt
}

model PlatformStats {
  id                  String   @id @default(cuid())
  symbol              String   @unique @default("ALL") // strategy symbol, or "ALL" for platform-wide aggregate
  activeBots          Int      @default(0)
  inactiveBots        Int      @default(0)
  activeBotsAllocInr  Float    @default(0)
  inactiveBotsAllocInr Float   @default(0)
  totalRealizedPnl    Float    @default(0)
  totalNetPnl         Float    @default(0)
  monthlyRealizedPnl  Float    @default(0)
  monthlyNetPnl       Float    @default(0)
  totalDeltaCharge    Float    @default(0)
  monthlyDeltaCharge  Float    @default(0)
  equityCurve         Json?
  updatedAt           DateTime @updatedAt
}

model UserDashboardStats {
  id              String   @id @default(cuid())
  userId          String
  symbol          String   // strategy symbol, or "ALL" for this user's combined aggregate
  totalRealizedPnl Float   @default(0)
  totalNetPnl     Float    @default(0)
  monthlyRealizedPnl Float @default(0)
  monthlyNetPnl   Float    @default(0)
  totalTrades     Int      @default(0)
  winRate         Float    @default(0)
  avgProfitLoss   Float    @default(0)
  avgTradeSize    Float    @default(0)
  equityCurve     Json?
  updatedAt       DateTime @updatedAt

  @@unique([userId, symbol])
}

model Strategy {
  id              String        @id @default(cuid())
  name            String
  symbol          String
  timeframe       String
  description     String?
  equityData      Json?
  totalPnlPct     Float?
  winRate         Float?
  maxDrawdown     Float?
  profitFactor    Float?
  totalTrades     Int?
  backtestFileName String?
  backtestFileUrl  String?
  properties      Json?
  initialCapitalUsd Float?
  webhookToken    String        @unique @default(cuid())
  minCapital      Float?        
  isFeatured      Boolean       @default(false)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  defaultLeverage Int      @default(1)
  showSubscriberCount Boolean @default(true)
  minLiveLot      Float?
  orderSizeType   String   @default("currency") // 'lot' | 'currency' | 'equity_pct'
  defaultOrderSizeValue Float? // for 'equity_pct' mode: the admin-set % applied to ALL subscribers
  subscribers     TradeConfig[]
}

model StrategyTrade {
  id               String   @id @default(cuid())
  strategyId       String
  side             String
  trade            String
  signal           String?
  price            Float?
  size             Float?
  netPnlUsd        Float?
  netPnlPct        Float?
  cumulativePnlUsd Float?
  tradeNumber      Int?
  symbol           String
  source           String   @default("live")
  firedAt          DateTime @default(now())
  totalFired       Int      @default(0)

  @@index([strategyId])
  @@index([firedAt])
  @@index([source])
}
