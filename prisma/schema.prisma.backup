generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?  @unique
  password   String?
  avatar     String?
  role       String   @default("user")
  phone      String   @default("")
  createdAt  DateTime @default(now())
  isVerified Boolean  @default(false)

  details      UserDetails?
  tradeConfigs TradeConfig[]
  Billing      Billing[]
  Payment      Payment[]
}

model UserDetails {
  id               String  @id @default(cuid())
  userId           String  @unique
  name             String
  age              Int
  gender           String
  city             String
  district         String
  country          String
  email            String
  phone            String
  deltaUserId      String?
  deltaAccountName String?
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  userId     String?
  createdAt  DateTime @default(now())
}

model TradeConfig {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  amount         Float
  initial_amount Float?
  isActive       Boolean  @default(false)
  userActive     Boolean  @default(true)
  script         String
  comission      Float?
  createdAt      DateTime @default(now())

  // Encrypted Delta API credentials
  api_key_enc    String   @default("")
  api_secret_enc String   @default("")

  // Delta account info (auto-fetched on key connect)
  delta_account_name String?
  delta_user_id      String?

  // Mode: "bridge" (TradingView) or "standalone" (built-in strategy)
  mode     String  @default("bridge")
  strategy String? // "pdh_pdl" etc. — used when mode = "standalone"

  // Standalone config
  timeframe     String? // "15m", "5m" etc.
  session_start String? // "09:15" IST
  session_end   String? // "22:55" IST
  risk_reward   Float   @default(3.0)

  platformFeePercent Float @default(20)

  lastToggledAt       DateTime?
  pause_lastToggledAt DateTime?
  lastEditAt          DateTime?

  Billing Billing[]

  @@index([isActive])
  @@unique([userId, script])
}

model Script {
  symbol          String  @id
  exchange_symbol String
  lot             Float   @default(1)
  exchange        String  @default("delta")
  algorithm       String?
  productId       Int
  Max_pos_size    Int     @default(15000)
  Pos_Per         Int     @default(100)
  gridEnabled     Boolean @default(false)
  defaultStrategy String?
}

model Billing {
  id                 String   @id @default(cuid())
  userId             String
  tradeConfigId      String
  month              String
  productId          Int
  netPnl             Float
  carryForward       Float    @default(0)
  billableAmount     Float
  platformFeePercent Float    @default(20)
  status             String   @default("unpaid")
  generatedAt        DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeConfig TradeConfig @relation(fields: [tradeConfigId], references: [id], onDelete: Cascade)
  Payment     Payment[]

  @@unique([month, tradeConfigId, productId])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  billingId         String?
  amountPaid        Float
  paymentDate       DateTime @default(now())
  method            String?
  razorpayPaymentId String?
  reference         String?  // for manual payments
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  billing           Billing? @relation(fields: [billingId], references: [id], onDelete: Cascade)
}
